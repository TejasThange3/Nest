{
  "info": {
    "name": "Nest Video Calling API",
    "description": "Complete API collection for Nest Video Calling application with authentication, chat, and video calling endpoints",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "indian_phone",
      "value": "+919970593046",
      "type": "string",
      "description": "Your verified Indian phone number for testing"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Send Phone Verification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{indian_phone}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/send-phone-code",
              "host": ["http://localhost:5000"],
              "path": ["api", "auth", "send-phone-code"]
            },
            "description": "Send SMS verification code to Indian phone number"
          }
        },
        {
          "name": "2. Verify Phone Number",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{indian_phone}}\",\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/verify-phone",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-phone"]
            },
            "description": "Verify the SMS code received on phone"
          }
        },
        {
          "name": "3. Send Email Verification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/send-email-code",
              "host": ["http://localhost:5000"],
              "path": ["api", "auth", "send-email-code"]
            },
            "description": "Send email verification code (goes to Mailtrap in development)"
          }
        },
        {
          "name": "4. Complete Registration",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{indian_phone}}\",\n  \"phoneCode\": \"123456\",\n  \"email\": \"test@example.com\",\n  \"emailCode\": \"123456\",\n  \"username\": \"testuser\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Complete user registration with verified phone and email"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', response.tokens.accessToken);",
                  "    pm.collectionVariables.set('user_id', response.user._id);",
                  "    console.log('Access token saved:', response.tokens.accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "5. Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{indian_phone}}\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Login with phone number and password"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', response.tokens.accessToken);",
                  "    pm.collectionVariables.set('user_id', response.user._id);",
                  "    console.log('Access token saved:', response.tokens.accessToken);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users/profile",
              "host": ["{{base_url}}"],
              "path": ["users", "profile"]
            },
            "description": "Get current user profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Updated\",\n  \"lastName\": \"Name\",\n  \"bio\": \"Updated bio\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/profile",
              "host": ["{{base_url}}"],
              "path": ["users", "profile"]
            },
            "description": "Update user profile information"
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users/search?query=test",
              "host": ["{{base_url}}"],
              "path": ["users", "search"],
              "query": [
                {
                  "key": "query",
                  "value": "test"
                }
              ]
            },
            "description": "Search for users by username, email, or name"
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Get Conversations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/chat/conversations",
              "host": ["{{base_url}}"],
              "path": ["chat", "conversations"]
            },
            "description": "Get all conversations for the current user"
          }
        },
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/chat/messages/USER_ID_HERE",
              "host": ["{{base_url}}"],
              "path": ["chat", "messages", "USER_ID_HERE"]
            },
            "description": "Get messages with a specific user (replace USER_ID_HERE with actual user ID)"
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipientId\": \"USER_ID_HERE\",\n  \"content\": \"Hello! This is a test message.\",\n  \"type\": \"text\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/chat/send",
              "host": ["{{base_url}}"],
              "path": ["chat", "send"]
            },
            "description": "Send a text message to another user"
          }
        }
      ]
    },
    {
      "name": "Video Calls",
      "item": [
        {
          "name": "Initiate Call",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipientId\": \"USER_ID_HERE\",\n  \"type\": \"video\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/calls/initiate",
              "host": ["{{base_url}}"],
              "path": ["calls", "initiate"]
            },
            "description": "Initiate a video call with another user"
          }
        },
        {
          "name": "Get Call History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/calls/history",
              "host": ["{{base_url}}"],
              "path": ["calls", "history"]
            },
            "description": "Get call history for the current user"
          }
        },
        {
          "name": "Update Call Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ended\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/calls/CALL_ID_HERE/status",
              "host": ["{{base_url}}"],
              "path": ["calls", "CALL_ID_HERE", "status"]
            },
            "description": "Update call status (replace CALL_ID_HERE with actual call ID)"
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Server Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/health",
              "host": ["http://localhost:5000"],
              "path": ["health"]
            },
            "description": "Check if the server is running"
          }
        }
      ]
    }
  ]
}
